<Page x:Class="CustomCodeSystem.Pages.PageLinkSns"
          xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
          xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
          xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
          xmlns:local="clr-namespace:CustomCodeSystem.Pages"
          mc:Ignorable="d"
          d:DesignHeight="700" d:DesignWidth="900"
          Title="PageLinkSns"
          Background="#F6F7FB">
    <Page.Resources>

        <!-- =========================
         CARD: shadow layer + surface layer
         ========================= -->
        

        <!-- нижний слой: только тень, без текста -->
        <Style x:Key="CardShadowStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="18"
                                  ShadowDepth="3"
                                  Opacity="0.12"/>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- верхний слой: карточка с контентом, БЕЗ эффектов -->
        <Style x:Key="CardSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- helper стиль для заголовков/текста: чёткий рендер -->
        <Style TargetType="TextBlock">
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Titles / text -->
        <Style x:Key="PageTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <!-- черный -->
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <!-- целое -->
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#111827"/>
            <!-- темный, читаемый -->
            <Setter Property="Opacity" Value="0.80"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <Style x:Key="CountText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>

        <Style x:Key="ErrorText" TargetType="TextBlock" BasedOn="{StaticResource HintText}">
            <Setter Property="Foreground" Value="#B91C1C"/>
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="Margin" Value="0,6,0,0"/>
        </Style>

        <!-- =========================
         TextBox: shadow underlay + chrome overlay (no effect on text)
         ========================= -->
        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <!-- shadow layer -->
                            <Border x:Name="shadow"
                                CornerRadius="10"
                                Background="#FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Opacity="0.14"/>
                                </Border.Effect>
                            </Border>

                            <!-- chrome + content layer (no effects here) -->
                            <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="0"
                                          VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Readonly -->
        <Style x:Key="ReadableTextBoxReadonly" TargetType="TextBox" BasedOn="{StaticResource ReadableTextBox}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
        </Style>

        <!-- Checkbox -->
        <Style x:Key="ReadableCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- =========================
         Button: shadow underlay + surface overlay
         ========================= -->
        <Style x:Key="ReadableButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="84"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <!-- shadow -->
                            <Border x:Name="shadow"
                                CornerRadius="10"
                                Background="#FFFFFF"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                  ShadowDepth="2"
                                                  Opacity="0.14"/>
                                </Border.Effect>
                            </Border>

                            <!-- surface (no effect) -->
                            <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ReadableButton}">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>


    <Grid UseLayoutRounding="True"
      SnapsToDevicePixels="True"
      TextOptions.TextFormattingMode="Display"
      TextOptions.TextRenderingMode="ClearType"
      TextOptions.TextHintingMode="Fixed"
      RenderOptions.ClearTypeHint="Enabled">

        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>

        </Grid.RowDefinitions>

        <Grid x:Name="gridError" Grid.Row="0" Visibility="Visible" VerticalAlignment="Center" HorizontalAlignment="Center">
            <StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Klaida bandant paleisti GOR operacija: "/>
                    <TextBlock x:Name="textBlockErrorGorCode"/>
                </StackPanel>
                <TextBlock x:Name="gridErrorErrorText"/>
                <Button x:Name="gridErrorBtn" 
                        Content="Bandyti dar karta" 
                        Click="gridErrorBtn_Click"                                     
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>

        </Grid>

        <Grid x:Name="gridMain" Grid.Row="1" Visibility="Visible">
            

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- =========================
             TOP ROW: two cards
             ========================= -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <!--<ColumnDefinition Width="300"/>-->
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
 
                <!-- GOR code CARD -->
                <Grid Grid.Column="0"
                      Visibility="Collapsed"
                  Margin="5"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                    <Border Style="{StaticResource CardShadowStyle}" />
                    <Border Style="{StaticResource CardSurfaceStyle}" Margin="0">
                        <StackPanel x:Name="stackGorCode">
                            <TextBlock Style="{StaticResource SectionTitle}" Text="GOR kodas"/>

                            <TextBox x:Name="textBoxGorCode"
                                 Style="{StaticResource ReadableTextBox}"
                                 KeyDown="textBoxGorCode_KeyDown"/>

                            <TextBlock x:Name="textBlockGorCodeError"
                                   Style="{StaticResource ErrorText}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Operation info CARD -->
                <Grid Grid.Column="1"
                  Margin="5"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
                    <Border Style="{StaticResource CardShadowStyle}" />
                    <Border Style="{StaticResource CardSurfaceStyle}" Margin="0">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}" Text="Operacijos informacija"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Left -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Operacijos kodas"/>
                                    <TextBox x:Name="textBoxOperationCode"
                                         Style="{StaticResource ReadableTextBoxReadonly}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Operacijos aprašymas"/>
                                    <TextBox x:Name="textBoxOperationDiscription"
                                         Style="{StaticResource ReadableTextBoxReadonly}"/>
                                </StackPanel>

                                <!-- Right -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Privalomos operacijos"/>
                                    <TextBox x:Name="textBoxMandatoryOperations"
                                         Style="{StaticResource ReadableTextBoxReadonly}"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="3" Margin="20,22,0,10">
                                    <CheckBox x:Name="checkBoxRepeatable"
                                          Style="{StaticResource ReadableCheckBox}"
                                          Content="Kartojama" IsEnabled="False"/>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="4" Margin="0,22,0,10" Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Atlikta operaciju: "/>
                                    <TextBlock Style="{StaticResource LabelText}" x:Name="textBlockCombletedCount" Text="0"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel x:Name="stackMain" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <!-- (Grid.Row="1" если у тебя там что-то есть - оставь как было) -->

            <!-- =========================
             SCAN CARD (Row 2)
             ========================= -->

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid x:Name="boarderScan"
                   Margin="5"
                   SnapsToDevicePixels="True"
                   UseLayoutRounding="True">
                    <Border Style="{StaticResource CardShadowStyle}" />
                    <Border Style="{StaticResource CardSurfaceStyle}" Margin="0" Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Grid VerticalAlignment="Center" Grid.Column="0">
                                <TextBlock Text="Gaminio operacinis/master kodas:"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="#000"/>
                            </Grid>

                            <Grid Grid.Column="1" Margin="10,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBox x:Name="textBoxLinkSn"
                          Grid.Column="0"
                              Width="200"
                          Margin="0,0,8,0"
                          Style="{StaticResource ReadableTextBox}"
                          KeyDown="textBoxLinkSn_KeyDown"/>

                                <Button Grid.Column="1"
                         Content="Clear"
                         Style="{StaticResource ReadableButton}"
                         Click="Button_Click"/>
                            </Grid>

                            <Grid Grid.Column="2" VerticalAlignment="Center">
                                <TextBlock 
                            x:Name="textBlockSearchResult"
                             Margin="15,8,0,0"
                            FontSize="13"
                            Foreground="#000"
                            TextWrapping="Wrap"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <!-- =========================
      APPLY CARD (Row 3)
      ========================= -->
                <Grid x:Name="borderApply"
                   Grid.Column="1"
                   Margin="5"
                   SnapsToDevicePixels="True"
                   UseLayoutRounding="True">
                    <Border Style="{StaticResource CardShadowStyle}" />
                    <Border Style="{StaticResource CardSurfaceStyle}" Margin="0" Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                                <TextBlock Text="Nuskenuok pativirtinomo 2D koda arba ivesk OK arba spasuk Enter kad patvirtinti"
                            Margin="0,2,0,0"
                                           Width="250"
                                           TextWrapping="Wrap"
                            FontSize="13"
                            Foreground="#000"
                            Opacity="0.78"/>


                            <TextBox Grid.Column="1"
                      x:Name="textBoxApply"
                      Margin="30,0,8,0"
                      Style="{StaticResource ReadableTextBox}"
                      KeyDown="textBoxApply_KeyDownAsync"/>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
       

            <!-- =========================
             MAIN AREA CARD (Row 4)
             ========================= -->
            <Grid x:Name="borderMainArea"
              Grid.Row="4"
              Margin="5"
              SnapsToDevicePixels="True"
              UseLayoutRounding="True">
                <Border Style="{StaticResource CardShadowStyle}" />
                <Border Style="{StaticResource CardSurfaceStyle}" Margin="0" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                        <WrapPanel x:Name="wrapPanelMultiSns"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>