<Page x:Class="CustomCodeSystem.Pages.PageLogin"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CustomCodeSystem.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PageLogin"
      Background="#F6F7FB">

    <Page.Resources>

        <!-- ====== CARD: shadow layer + surface layer (no blur on text) ====== -->

        <Style x:Key="CardShadowStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.14"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Global crisp text -->
        <Style TargetType="TextBlock">
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Rounded readable TextBox (shadow underlay + chrome overlay) -->
        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">

                            <!-- shadow layer (no text here) -->
                            <Border x:Name="shadow"
                                    CornerRadius="10"
                                    Background="#FFFFFF"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10"
                                                      ShadowDepth="2"
                                                      Opacity="0.14"/>
                                </Border.Effect>
                            </Border>

                            <!-- chrome/content layer (no effects => crisp text) -->
                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0"
                                              VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="shadow" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TitleText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Opacity" Value="0.75"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <!-- Rounded-rectangle RadioButton (no effects, crisp) -->
        <Style x:Key="RoundedRadioButton" TargetType="RadioButton">
            <Setter Property="Height" Value="34"/>
            <Setter Property="MinWidth" Value="100"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="bd"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="10"
                        SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>

                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#111827"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#111827"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>

                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Page.Resources>

    <Grid UseLayoutRounding="True"
          SnapsToDevicePixels="True"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          TextOptions.TextHintingMode="Fixed"
          RenderOptions.ClearTypeHint="Enabled">

        <!-- Card composed of shadow + surface -->
        <Grid Width="360"
              Margin="0,0,0,100"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Border Grid.Row="0"  Style="{StaticResource CardShadowStyle}"/>
            <Border Grid.Row="0" Style="{StaticResource CardSurfaceStyle}">

                <StackPanel>
                    <TextBlock Style="{StaticResource TitleText}" Text="Prisijungimas"/>

                    <TextBlock Style="{StaticResource HintText}"
                               Margin="0,4,0,14"
                               Text="Įvesk GOR ID ir paspausk Enter."/>

                    <TextBox x:Name="loginTextBox"
                             Style="{StaticResource ReadableTextBox}"
                             KeyDown="loginTextBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <RadioButton x:Name="radioMoletai"
                             Content="Moletai"
                             GroupName="LoginMode"
                             Style="{StaticResource RoundedRadioButton}"
                             IsChecked="True"/>

                        <RadioButton x:Name="radioDitva"
                             Content="Ditva"
                             GroupName="LoginMode"
                             Style="{StaticResource RoundedRadioButton}"
                             Margin="10,0,0,0"/>

                        <RadioButton x:Name="radioSvyla"
                            Content="Svyla"
                            GroupName="LoginMode"
                            Style="{StaticResource RoundedRadioButton}"
                            Margin="10,0,0,0"/>
                    </StackPanel>
                    <TextBlock x:Name="msgTextBox"
                               Margin="0,10,0,0"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#000000"
                               TextWrapping="Wrap"/>
                </StackPanel>

            </Border>

            <Border Margin="0,10,0,0" Grid.Row="1"  Style="{StaticResource CardShadowStyle}"/>
            <Border Margin="0,10,0,0" Grid.Row="1" Style="{StaticResource CardSurfaceStyle}">

                <StackPanel>
                    <TextBlock x:Name="textBoxInit"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="#000000"
                               TextWrapping="Wrap"/>
                </StackPanel>

            </Border>
        </Grid>
    </Grid>
</Page>
