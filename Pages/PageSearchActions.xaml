<Page x:Class="CustomCodeSystem.Pages.PageSearchActions"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:CustomCodeSystem.Pages"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="1000"
      Title="PageSearchActions"
      Background="#F6F7FB">

    <Page.Resources>

        <!-- Global crisp text -->
        <Style TargetType="TextBlock">
            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Card: shadow + surface (no blur on content) -->
        <Style x:Key="CardShadowStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="IsHitTestVisible" Value="False"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.14"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CardSurfaceStyle" TargetType="Border">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <!-- Titles -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="LabelText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="HintText" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Opacity" Value="0.70"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>

        <!-- TextBox: shadow underlay + chrome overlay -->
        <Style x:Key="ReadableTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>

            <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType"/>
            <Setter Property="TextOptions.TextHintingMode" Value="Fixed"/>
            <Setter Property="RenderOptions.ClearTypeHint" Value="Enabled"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Border x:Name="shadow"
                                    CornerRadius="10"
                                    Background="#FFFFFF"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.14"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Margin="0"
                                              VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="shadow" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DatePicker: make it look like TextBox (re-using ReadableTextBox) -->
        <!-- DatePicker: looks like TextBox + opens calendar -->
        <Style x:Key="ReadableDatePicker" TargetType="DatePicker">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DatePicker">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="34"/>
                            </Grid.ColumnDefinitions>

                            <!-- Text part -->
                            <DatePickerTextBox x:Name="PART_TextBox"
                                       Grid.Column="0"
                                       Style="{StaticResource ReadableTextBox}"
                                       Height="34"
                                       VerticalContentAlignment="Center"/>

                            <!-- Drop-down button MUST be ToggleButton named PART_Button -->
                            <ToggleButton x:Name="PART_Button"
                                  Grid.Column="1"
                                  Focusable="False"
                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                  Background="#F3F4F6"
                                  BorderBrush="#D1D5DB"
                                  BorderThickness="1"
                                  Cursor="Hand">
                                <TextBlock Text="📅"
                                   FontSize="14"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>
                            </ToggleButton>

                            <!-- Popup + Calendar (this is what you were missing) -->
                            <Popup x:Name="PART_Popup"
                           Placement="Bottom"
                           AllowsTransparency="True"
                           Focusable="False"
                           StaysOpen="False"
                           IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border Background="White"
                                BorderBrush="#D1D5DB"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="6">
                                    <Calendar x:Name="PART_Calendar"
                                      IsTodayHighlighted="True"
                                      SelectedDate="{Binding SelectedDate, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                      DisplayDate="{Binding DisplayDate, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"/>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Buttons -->
        <Style x:Key="ReadableButton" TargetType="Button">
            <Setter Property="Height" Value="34"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Background" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#D1D5DB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="UseLayoutRounding" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Border x:Name="shadow"
                                    CornerRadius="10"
                                    Background="#FFFFFF"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.14"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#EEF2FF"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#E5E7EB"/>
                                <Setter TargetName="shadow" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="shadow" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource ReadableButton}">
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#111827"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid SnapsToDevicePixels="True" UseLayoutRounding="True">
                            <Border x:Name="shadow"
                                    CornerRadius="10"
                                    Background="#FFFFFF"
                                    BorderBrush="Transparent"
                                    BorderThickness="1"
                                    IsHitTestVisible="False">
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.16"/>
                                </Border.Effect>
                            </Border>

                            <Border x:Name="bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="10"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.92"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                <Setter TargetName="shadow" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.55"/>
                                <Setter TargetName="shadow" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid -->
        <Style x:Key="ReadableDataGrid" TargetType="DataGrid">
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="None"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="EnableRowVirtualization" Value="True"/>
            <Setter Property="EnableColumnVirtualization" Value="True"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F9FAFB"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#F1F5F9"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAFAFB"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EEF2FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InverseBoolConverter x:Key="InvBool"/>

    </Page.Resources>

    <Grid Margin="18"
          UseLayoutRounding="True"
          SnapsToDevicePixels="True"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          TextOptions.TextHintingMode="Fixed"
          RenderOptions.ClearTypeHint="Enabled">
        <Grid IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- FILTERS CARD -->
        <Grid Grid.Row="0" Margin="0,0,0,12" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border Style="{StaticResource CardShadowStyle}"/>
            <Border Style="{StaticResource CardSurfaceStyle}" Margin="0">

                <StackPanel>
                    <TextBlock Style="{StaticResource SectionTitle}" Text="Paieška"/>

                    <!-- 2 columns form -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>

                                    <ColumnDefinition Width="*"/>

                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>

                                </Grid.RowDefinitions>

                                <!-- Date From -->
                                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Date from"/>
                                    <DatePicker x:Name="datePickerDateFrom"
                                                Style="{StaticResource ReadableDatePicker}"
                                                SelectedDate="{Binding MyDate}"
                                                SelectedDateFormat="Short"/>
                                </StackPanel>

                                <!-- Date To -->
                                <StackPanel Grid.Column="0" Grid.Row="1" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Date to"/>
                                    <DatePicker x:Name="datePickerDateTo"
                                                Style="{StaticResource ReadableDatePicker}"
                                                SelectedDate="{Binding MyDate}"
                                                SelectedDateFormat="Short"/>
                                </StackPanel>


                                <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Operational/CustomSn"/>
                                    <TextBox x:Name="textBoxOperationalCustomSn" Style="{StaticResource ReadableTextBox}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1" Grid.Row="1" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Operation"/>
                                    <TextBox x:Name="textBoxOperation" Style="{StaticResource ReadableTextBox}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Worker ID"/>
                                    <TextBox x:Name="textBoxWorkerId" Style="{StaticResource ReadableTextBox}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2" Grid.Row="1" Margin="0,0,12,10">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Worker name"/>
                                    <TextBox x:Name="textBoxWorkerName" Style="{StaticResource ReadableTextBox}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="3" Grid.Row="0" Margin="0,0,12,0">
                                    <TextBlock Style="{StaticResource LabelText}" Text="Worker surname"/>
                                    <TextBox x:Name="textBoWorkerSurname" Style="{StaticResource ReadableTextBox}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Grid.Row="0" Margin="0,0,12,10" VerticalAlignment="Bottom">
                                    <Button x:Name="btnSearch"
                                            Content="Ieškoti"
                                            MinWidth="140"
                                            Click="btnSearch_Click"
                                            Style="{StaticResource PrimaryButton}"/>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Grid.Row="1" Margin="0,0,12,10" VerticalAlignment="Bottom">
                                    <Button x:Name="btnClear"
                                            Content="Isvalyti"
                                            MinWidth="140"
                                            Click="btnClear_Click"
                                            Style="{StaticResource PrimaryButton}"/>
                                </StackPanel>

                            </Grid>
                            <Grid x:Name="gridInfo" Grid.Row="1" Visibility="Collapsed">
                                <TextBlock x:Name="textBlockInfo" Foreground="Red" FontSize="20" TextAlignment="Center"/>
                            </Grid>
                        </Grid>
                    </StackPanel>

            </Border>
        </Grid>

        <!-- RESULTS CARD -->
        <Grid Grid.Row="1" SnapsToDevicePixels="True" UseLayoutRounding="True">
            <Border Style="{StaticResource CardShadowStyle}"/>
            <Border Style="{StaticResource CardSurfaceStyle}" Margin="0" Padding="0">

                <DataGrid x:Name="dgCompletedActions"

                          Style="{StaticResource ReadableDataGrid}"
                          ItemsSource="{Binding CompletedActions}"
                          Margin="0">

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding ConnectDateTime, StringFormat={}{0:yyyy-MM-dd HH:mm:ss}}" Width="160"/>
                            <DataGridTextColumn Header="WorkerId" Binding="{Binding WorkerId}" Width="120"/>
                            <DataGridTextColumn Header="Name" Binding="{Binding WorkerName}" Width="120"/>
                            <DataGridTextColumn Header="Surname" Binding="{Binding WorkerSurname}" Width="120"/>
                            <DataGridTextColumn Header="Operation" Binding="{Binding OperationCode}" Width="90"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding OperationDescription}" Width="220"/>
                            <DataGridTextColumn Header="Operational" Binding="{Binding OperationalNumber}" Width="140"/>
                            <DataGridTextColumn Header="Serial" Binding="{Binding SerialNumber}" Width="140"/>
                            <DataGridTextColumn Header="IMEI" Binding="{Binding Imei}" Width="140"/>
                            <DataGridCheckBoxColumn Header="Pass" Binding="{Binding Pass}" Width="60"/>
                            <DataGridTextColumn Header="Comment" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>

                    </DataGrid>

                </Border>
            </Grid>
        </Grid>

        <!-- OVERLAY НА ВРЕМЯ ЗАГРУЗКИ -->

        <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
          IsHitTestVisible="True">

            <Border Background="White"
                CornerRadius="14"
                Padding="18"
                Width="320"
                BorderBrush="Black"
                  BorderThickness="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Loading..."
                           FontSize="14"
                           FontWeight="SemiBold"
                           Margin="0,0,0,10"/>

                    <ProgressBar IsIndeterminate="True" Height="10"/>

                    <TextBlock Text="{Binding StatusText}"
                           Opacity="0.7"
                           Margin="0,10,0,0"
                           TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Page>
